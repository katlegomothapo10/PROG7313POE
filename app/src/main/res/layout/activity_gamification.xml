<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_card_bg">

    <!-- Bottom Navigation Bar - MUST BE DEFINED FIRST -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#0d0d1a"
        android:elevation="8dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/navInsights"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Insights"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/navAwards"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Awards"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profile"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Scrollable Content - NOW CAN REFERENCE bottomNavigation -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:padding="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header with Back Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Back"
                    app:tint="#FFFFFF"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Awards"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Your 6 badges earned! title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Your 6 badges earned!"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Row 1: Badge 1, 2, 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <!-- Badge 1: 7 day streak -->
                <LinearLayout
                    android:id="@+id/badge1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/badge_earned">

                    <TextView
                        android:id="@+id/badge1Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🔥"
                        android:textSize="36sp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge1Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="7 day streak"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge1Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Earned"
                        android:textColor="#FFD700"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Badge 2: Savvy hoarder -->
                <LinearLayout
                    android:id="@+id/badge2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/badge_earned">

                    <TextView
                        android:id="@+id/badge2Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="💰"
                        android:textSize="36sp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge2Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Savvy hoarder"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge2Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Earned"
                        android:textColor="#FFD700"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Badge 3: Budget pro -->
                <LinearLayout
                    android:id="@+id/badge3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/badge_earned">

                    <TextView
                        android:id="@+id/badge3Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🏆"
                        android:textSize="36sp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge3Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Budget pro"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge3Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Earned"
                        android:textColor="#FFD700"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Badge 4, 5, 6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- Badge 4: Challenge winner -->
                <LinearLayout
                    android:id="@+id/badge4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/badge_earned">

                    <TextView
                        android:id="@+id/badge4Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🥇"
                        android:textSize="36sp"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge4Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Challenge winner"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge4Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Earned"
                        android:textColor="#FFD700"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Badge 5: Doomsday preparer (LOCKED) -->
                <LinearLayout
                    android:id="@+id/badge5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/badge_locked">

                    <TextView
                        android:id="@+id/badge5Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🛡️"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:alpha="0.5"/>

                    <TextView
                        android:id="@+id/badge5Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Doomsday preparer"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge5Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Locked"
                        android:textColor="#888888"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Badge 6: Level 5 ninja (LOCKED) -->
                <LinearLayout
                    android:id="@+id/badge6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:background="@drawable/badge_locked">

                    <TextView
                        android:id="@+id/badge6Icon"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:text="🥷"
                        android:textSize="36sp"
                        android:gravity="center"
                        android:alpha="0.5"/>

                    <TextView
                        android:id="@+id/badge6Name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Level 5 ninja"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/badge6Status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Locked"
                        android:textColor="#888888"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Budget Master Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Budget Master"
                android:textColor="#FFD700"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center"/>

            <!-- Next badge section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Next badge:"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/gradient_card_bg"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvNextBadgeName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Saving star"
                    android:textColor="#FFD700"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvNextBadgeProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R350/R1000"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressNextBadge"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:progress="35"
                android:max="100"
                android:progressTint="#FFD700"
                android:progressBackgroundTint="#333355"/>

            <!-- Bottom padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:visibility="invisible"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>