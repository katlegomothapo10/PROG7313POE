<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_black_blue"
    tools:context=".ui.MainActivity">

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/btnUsername"
        android:layout_width="353dp"
        android:layout_height="51dp"

        android:layout_marginStart="40dp"
        android:background="@drawable/btn_white"
        android:backgroundTint="@null"
        android:gravity="center"
        android:hint="DoomsdaySavvy"
        android:textColorHint="@color/black"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/usernameTextView" />

    <TextView
        android:id="@+id/usernameTextView"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:text="Username"
        android:textAlignment="center"
        android:textColor="#FFF4B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.105"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView"
        app:layout_constraintVertical_bias="0.0" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/btnPassword"
        android:layout_width="353dp"
        android:layout_height="51dp"

        android:layout_marginStart="40dp"
        android:background="@drawable/btn_white"
        android:backgroundTint="@null"
        android:gravity="center"
        android:hint="**********"
        android:textColorHint="@color/black"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/passwordTextView" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/btnEmail"
        android:layout_width="353dp"
        android:layout_height="51dp"

        android:layout_marginStart="40dp"
        android:layout_marginTop="4dp"

        android:background="@drawable/btn_white"
        android:backgroundTint="@null"
        android:gravity="center"
        android:hint="user@gmail.com"
        android:textColorHint="@color/black"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/EmailTextView" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/btnConfirmPassword"
        android:layout_width="353dp"
        android:layout_height="51dp"

        android:layout_marginStart="40dp"
        android:layout_marginTop="2dp"

        android:background="@drawable/btn_white"
        android:backgroundTint="@null"
        android:gravity="center"
        android:hint="**********"
        android:textColorHint="@color/black"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/confirmPasswordTextView" />

    <TextView
        android:id="@+id/confirmPasswordTextView"
        android:layout_width="200dp"
        android:layout_height="40dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="12dp"
        android:text="Confirm Password"
        android:textColor="#FFF4B0"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnPassword" />

    <TextView
        android:id="@+id/passwordTextView"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="236dp"
        android:text="Password"
        android:textAlignment="center"
        android:textColor="#FFF4B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.105"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnEmail"
        app:layout_constraintVertical_bias="1.0" />

    <TextView
        android:id="@+id/EmailTextView"
        android:layout_width="50dp"
        android:layout_height="40dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="344dp"
        android:text="Email"
        android:textAlignment="center"
        android:textColor="#FFF4B0"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.09"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnUsername"
        app:layout_constraintVertical_bias="0.571" />

    <TextView
        android:id="@+id/headingTextView"
        android:layout_width="355dp"
        android:layout_height="50dp"
        android:text="@string/app_name"
        android:textAlignment="center"
        android:textColor="#FAF3F3"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.464"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.145" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSignin"
        android:layout_width="183dp"
        android:layout_height="67dp"

        android:layout_marginStart="128dp"

        android:layout_marginTop="8dp"
        android:background="@drawable/btn_gradient"
        android:gravity="center"

        android:text="Signin"
        android:textColor="@color/black"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnConfirmPassword" />

    <ImageView
        android:id="@+id/logo"
        android:layout_width="94dp"
        android:layout_height="83dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/logo1" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="103dp"
        android:layout_height="85dp"
        android:layout_marginStart="162dp"
        android:layout_marginTop="9dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headingTextView"
        android:src="@drawable/profile" />

</androidx.constraintlayout.widget.ConstraintLayout>